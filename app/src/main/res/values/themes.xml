<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme Material3 -->
    <style name="Theme.SPBUReceiptPrinter" parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- SplashScreen theme -->
    <style name="Theme.SPBUReceiptPrinter.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pertamina_red</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.SPBUReceiptPrinter</item>
    </style>
</resources>
